          ],
          "priority": "P0"
        },
        {
          "id": "PS-002",
          "name": "Suggested neighborhoods / areas to stay",
          "edge_case_ref": null,
          "input": {
            "request": "Plan a 5-day trip to Japan. Tokyo + Kyoto. $3,000 budget. Love food and temples, hate crowds."
          },
          "assertions": [
            { "type": "array_min_length", "path": "neighborhoods_to_stay", "min": 1 },
            { "type": "each_has_keys", "path": "neighborhoods_to_stay", "keys": ["city", "recommended_neighborhood", "reason"] }
          ],
          "priority": "P0"
        },
        {
          "id": "PS-003",
          "name": "Travel logistics between cities",
          "edge_case_ref": null,
          "input": {
            "request": "Plan a 5-day trip to Japan. Tokyo + Kyoto. $3,000 budget. Love food and temples, hate crowds."
          },
          "assertions": [
            { "type": "field_exists", "path": "logistics" },
            { "type": "array_min_length", "path": "logistics.inter_city", "min": 1 }
          ],
          "priority": "P0"
        },
        {
          "id": "PS-004",
          "name": "Budget-friendly recommendations",
          "edge_case_ref": null,
          "input": {
            "request": "Plan a 5-day trip to Japan. Tokyo + Kyoto. $3,000 budget. Love food and temples, hate crowds."
          },
          "assertions": [
            { "type": "field_exists", "path": "budget" },
