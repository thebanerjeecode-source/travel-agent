# Groq — planning agents
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini — review agents
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.5-flash

# Optional
MAX_REVISION_LOOPS=1

# Phase 4 — data layer (optional)
OPENTRIPMAP_API_KEY=
DATA_MODE=auto

# Optional live APIs (Phase 4+)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
GOOGLE_MAPS_API_KEY=

# Rate limits (defaults — see docs/implementation-plan.md)
GROQ_RPM=30
GROQ_RPD=1000
GEMINI_RPM=5
GEMINI_RPD=20
GEMINI_RPD_WARN_THRESHOLD=0.8

# Phase 6 — API + frontend
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_SECRET=
PORT=8000
